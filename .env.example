NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/blog_management
CLIENT_URL=http://localhost:5173
JWT_SECRET=replace_with_64_character_secret
JWT_REFRESH_SECRET=replace_with_64_character_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
GEMINI_API_KEY=your_google_gemini_api_key
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user
SMTP_PASS=password
SMTP_FROM=Blog Platform <noreply@example.com>
VITE_API_URL=http://localhost:5000/api/v1
